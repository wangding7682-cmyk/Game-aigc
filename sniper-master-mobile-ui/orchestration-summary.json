    "styleDefinitionBrief": "移动端狙击游戏界面，深蓝黑战术底色搭配高亮红主强调，轻写实城市环境里混入卡通外星目标，强调扫描、锁定、命中与结算成长的爽感。",
    "designRead": "移动端狙击玩法 / 新手与轻竞技用户 / 工业战术沉浸 / 中高密度 / 避免赛博霓虹和二次元跳脱",
    "designDials": {
      "layoutVariance": 2,
      "motionIntensity": 2,
      "visualDensity": 4
    },
    "styleContinuityAnchors": {
      "colorSystem": {
        "primaryColorRole": "高亮红只用于主按钮、关键锁定、命中与危险提示；大面积保持深蓝黑和钢蓝灰",
        "brandHuePolicy": "统一深夜城市场景色温，不做跳脱的多彩渐变，不引入第二品牌色",
        "stateColors": "成功绿用于结算奖励，信息蓝用于扫描与教程提示，警告橙用于倒计时与失败风险"
      },
      "shapeSystem": "圆角控制在 4/8/14px，保持战术面板的硬朗结构，按钮和芯片为紧凑胶囊态",
      "typographySystem": "标题用中文无衬线加粗，正文保持清晰易读，数字和计时使用等宽字体增强 HUD 感",
      "spacingSystem": "顶部 HUD 与底部操作区紧凑，中部主视区留出观察空间，卡片内边距以 12/16/20px 为主",
      "componentLanguage": "玻璃化战术面板、细描边、准星元素、雷达环、任务芯片、双层按钮",
      "surfaceAndDepth": "静态卡片以边框和半透明叠层为主，只有弹窗和浮层使用更深阴影",
      "imageryAndIconography": "场景图围绕城市夜景、狙击镜、伪装外星目标；图标偏战术 HUD 线性风格",
      "interactionTone": "反馈明确、短促、有战斗节奏感，避免花哨弹跳"
    },
    "specsConstraints": null,
    "sharedProjectShellContract": {
      "navigationShell": "所有页面保持单手操作友好的移动端安全区容器，顶部信息栏与底部主操作区语言统一",
      "primaryColorSystem": "主强调色统一使用品牌红，扫描和信息提示使用状态蓝，整体仍以深蓝黑为底",
      "typographySystem": "标题加粗，正文清晰，数字 HUD 使用等宽数字",
      "radiusScale": "面板 14px，二级卡片 8px，细节芯片 9999px",
      "surfaceDepthModel": "半透明暗色面板 + 细边框 + 微弱环境辉光，浮层可用更重遮罩",
      "ctaStyle": "主按钮为高亮红渐变，次按钮为透明描边，均保持厚重的移动端点击尺寸",
      "alignmentRules": "全局 24px 外边距基线，模块内部以 12-16px 节奏排列，HUD 信息左右对齐"
    },
